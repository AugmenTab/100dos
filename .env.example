# Foundry VTT credentials — copy this file to .env and fill in one of the options below.
# .env is gitignored and must never be committed.

# Option 1: Foundry account credentials (the container downloads Foundry automatically)
FOUNDRY_USERNAME=
FOUNDRY_PASSWORD=

# Option 2: Pre-signed download URL from foundryvtt.com > Purchased Licenses
# FOUNDRYVTT_PRESIGNED_URL=

# Option 3: License key (if Foundry has already been downloaded into foundrydata/)
# FOUNDRY_LICENSE_KEY=
